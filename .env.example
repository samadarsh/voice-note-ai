# Copy to .env and fill in real values (never commit .env)
# Get a Groq key: https://console.groq.com/keys  (must start with gsk_)
GROQ_API_KEY=gsk_replace_with_your_key_from_console
GROQ_MODEL=llama-3.1-8b-instant

# Whisper ASR (optional)
WHISPER_MODEL=small
WHISPER_MODEL_TAMIL=medium
# WHISPER_DEVICE=cuda
# WHISPER_FP16=true

# Long-audio chunking
CHUNK_DURATION_SEC=30
BUFFER_MAX_QUEUE=10
CHUNK_SAMPLE_RATE=16000

# App
OUTPUTS_DIR=outputs
SESSION_MAX_FILES=20
LOG_LEVEL=INFO
