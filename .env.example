# Optional overrides. Copy to .env (never commit .env).
# All values have sensible defaults in models/model_config.py.

# ASR
WHISPER_MODEL_ID=openai/whisper-medium   # e.g. openai/whisper-small for faster CPU
ASR_LANGUAGE=ta                          # transcription language
ASR_DEVICE=cpu                           # set "cuda" if a GPU is available

# Long-audio chunking
CHUNK_DURATION_SEC=30
BUFFER_MAX_QUEUE=10
CHUNK_SAMPLE_RATE=16000

# Gradio server
GRADIO_SERVER_NAME=0.0.0.0
GRADIO_SERVER_PORT=7860
# PORT=7860          # used by Render/Railway; takes effect if GRADIO_SERVER_PORT unset
# GRADIO_SHARE=true  # temporary public share URL

# Output
OUTPUTS_DIR=outputs
